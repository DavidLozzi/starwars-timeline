{
  "env": {
    "browser": true,
    "es2020": true
  },
  "settings": {
    "react": {
      "version": "17.0"
    }
  },
  "extends": [
    "plugin:json/recommended",
    "eslint:recommended",
    "plugin:react/recommended"
  ],
  "globals": {
    "gtag": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "json/*": [
      "error"
    ],
    "indent": [
      "error",
      2,
      {
        "SwitchCase": 1
      }
    ],
    "no-unused-vars": 0,
    "quotes": [
      "error",
      "single"
    ],
    "react/prop-types": "off",
    "react/jsx-uses-vars": 1,
    "react/react-in-jsx-scope": 1,
    "semi": "error"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.js",
        "**/__tests__/**/*.js"
      ],
      "env": {
        "jest": true
      },
      "rules": {
        "react/react-in-jsx-scope": "off"
      }
    }
  ]
}